<Window x:Class="KidGuard.Client.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="KidGuard"
        Height="640"
        Width="980"
        MinHeight="560"
        MinWidth="860"
        Background="{StaticResource WindowBackgroundBrush}"
        WindowStartupLocation="CenterScreen">
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="260" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <Border Grid.Column="0" Background="#111827">
            <Grid Margin="24">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <StackPanel>
                    <TextBlock Text="KidGuard" FontSize="26" FontWeight="Bold" Foreground="White" />
                    <TextBlock Text="Windows Client" Margin="0,4,0,0" Foreground="#CBD5E1" />
                </StackPanel>

                <StackPanel Grid.Row="1" VerticalAlignment="Center">
                    <TextBlock Text="Select role" Foreground="#CBD5E1" FontWeight="SemiBold" />
                    <Button x:Name="ParentModeButton"
                            Content="Parent"
                            Margin="0,12,0,8"
                            Style="{StaticResource PrimaryButtonStyle}"
                            Click="ParentModeButton_Click" />
                    <Button x:Name="ChildModeButton"
                            Content="Child"
                            Style="{StaticResource SecondaryButtonStyle}"
                            Click="ChildModeButton_Click" />
                </StackPanel>

                <TextBlock Grid.Row="2"
                           Text="Service protection stays separate from this client."
                           Foreground="#94A3B8"
                           FontSize="12" />
            </Grid>
        </Border>

        <Grid Grid.Column="1" Margin="34">
            <Grid x:Name="RoleSelectionPanel">
                <StackPanel VerticalAlignment="Center" MaxWidth="560">
                    <TextBlock Text="Choose how this Windows device will use KidGuard"
                               FontSize="30"
                               FontWeight="Bold" />
                    <TextBlock Text="Parent manages approved child devices. Child shows a connection code and approves pairing before protection starts."
                               Margin="0,14,0,28"
                               FontSize="15"
                               Foreground="{StaticResource MutedTextBrush}" />
                    <UniformGrid Columns="2">
                        <Button Content="Parent Mode"
                                Height="96"
                                Margin="0,0,10,0"
                                FontSize="17"
                                Style="{StaticResource PrimaryButtonStyle}"
                                Click="ParentModeButton_Click" />
                        <Button Content="Child Mode"
                                Height="96"
                                Margin="10,0,0,0"
                                FontSize="17"
                                Style="{StaticResource SecondaryButtonStyle}"
                                Click="ChildModeButton_Click" />
                    </UniformGrid>
                </StackPanel>
            </Grid>

            <Grid x:Name="ParentPanel" Visibility="Collapsed">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <DockPanel Margin="0,0,0,24">
                    <Button Content="Back"
                            DockPanel.Dock="Right"
                            Width="92"
                            Style="{StaticResource SecondaryButtonStyle}"
                            Click="BackButton_Click" />
                    <StackPanel>
                        <TextBlock Text="Parent Mode" FontSize="28" FontWeight="Bold" />
                        <TextBlock Text="Login and request pairing with a child device."
                                   Foreground="{StaticResource MutedTextBrush}"
                                   Margin="0,4,0,0" />
                    </StackPanel>
                </DockPanel>

                <Grid Grid.Row="1">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="1.05*" />
                        <ColumnDefinition Width="0.95*" />
                    </Grid.ColumnDefinitions>

                    <Border Background="{StaticResource PanelBackgroundBrush}"
                            BorderBrush="{StaticResource BorderBrush}"
                            BorderThickness="1"
                            CornerRadius="8"
                            Padding="24"
                            Margin="0,0,12,0">
                        <StackPanel>
                            <TextBlock Text="Account" FontSize="18" FontWeight="SemiBold" />
                            <TextBlock Text="API base URL" Margin="0,18,0,0" />
                            <TextBox x:Name="ApiBaseUrlTextBox" />
                            <TextBlock Text="Email" Margin="0,18,0,0" />
                            <TextBox x:Name="ParentEmailTextBox" />
                            <TextBlock Text="Password" />
                            <PasswordBox x:Name="ParentPasswordBox" />
                            <StackPanel Orientation="Horizontal">
                                <Button x:Name="ParentLoginButton"
                                        Content="Login"
                                        Width="112"
                                        Style="{StaticResource PrimaryButtonStyle}"
                                        Click="ParentLoginButton_Click" />
                                <Button x:Name="ParentRegisterButton"
                                        Content="Register"
                                        Width="112"
                                        Margin="10,0,0,0"
                                        Style="{StaticResource SecondaryButtonStyle}"
                                        IsEnabled="False"
                                        ToolTip="Waiting for the Version 1.0.1 Parent Register API." />
                            </StackPanel>
                            <TextBlock x:Name="ParentLoginStatusTextBlock"
                                       Text="Set KIDGUARD_API_BASE_URL before login."
                                       Margin="0,16,0,0"
                                       Foreground="{StaticResource MutedTextBrush}" />
                        </StackPanel>
                    </Border>

                    <Border Grid.Column="1"
                            Background="{StaticResource PanelBackgroundBrush}"
                            BorderBrush="{StaticResource BorderBrush}"
                            BorderThickness="1"
                            CornerRadius="8"
                            Padding="24"
                            Margin="12,0,0,0">
                        <StackPanel>
                            <TextBlock Text="Pairing" FontSize="18" FontWeight="SemiBold" />
                            <TextBlock Text="Child connection code" Margin="0,18,0,0" />
                            <TextBox x:Name="ChildCodeTextBox" CharacterCasing="Upper" MaxLength="12" />
                            <Button Content="Send Request"
                                    Width="140"
                                    HorizontalAlignment="Left"
                                    Style="{StaticResource PrimaryButtonStyle}" />
                            <Border Background="#F9FAFB"
                                    BorderBrush="{StaticResource BorderBrush}"
                                    BorderThickness="1"
                                    CornerRadius="8"
                                    Padding="14"
                                    Margin="0,22,0,0">
                                <TextBlock Text="Pairing status will appear here after the Backend APIs are available."
                                           Foreground="{StaticResource MutedTextBrush}" />
                            </Border>
                        </StackPanel>
                    </Border>
                </Grid>
            </Grid>

            <Grid x:Name="ChildPanel" Visibility="Collapsed">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <DockPanel Margin="0,0,0,24">
                    <Button Content="Back"
                            DockPanel.Dock="Right"
                            Width="92"
                            Style="{StaticResource SecondaryButtonStyle}"
                            Click="BackButton_Click" />
                    <StackPanel>
                        <TextBlock Text="Child Mode" FontSize="28" FontWeight="Bold" />
                        <TextBlock Text="Show a code, review parent requests, then approve protection."
                                   Foreground="{StaticResource MutedTextBrush}"
                                   Margin="0,4,0,0" />
                    </StackPanel>
                </DockPanel>

                <Grid Grid.Row="1">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="0.95*" />
                        <ColumnDefinition Width="1.05*" />
                    </Grid.ColumnDefinitions>

                    <Border Background="{StaticResource PanelBackgroundBrush}"
                            BorderBrush="{StaticResource BorderBrush}"
                            BorderThickness="1"
                            CornerRadius="8"
                            Padding="24"
                            Margin="0,0,12,0">
                        <StackPanel>
                            <TextBlock Text="Connection Code" FontSize="18" FontWeight="SemiBold" />
                            <TextBlock Text="API base URL" Margin="0,18,0,0" />
                            <TextBox x:Name="ChildApiBaseUrlTextBox" />
                            <TextBlock Text="Setup token" />
                            <PasswordBox x:Name="ChildSetupTokenPasswordBox" />
                            <TextBlock Text="Device name" />
                            <TextBox x:Name="ChildDeviceNameTextBox" />
                            <Border Background="#EFF6FF"
                                    BorderBrush="#BFDBFE"
                                    BorderThickness="1"
                                    CornerRadius="8"
                                    Padding="18"
                                    Margin="0,18,0,16">
                                <TextBlock x:Name="ConnectionCodeTextBlock"
                                           Text="WAITING"
                                           FontSize="34"
                                           FontWeight="Bold"
                                           TextAlignment="Center"
                                           Foreground="#1D4ED8" />
                            </Border>
                            <Button x:Name="CreateCodeButton"
                                    Content="Create Code"
                                    Width="132"
                                    HorizontalAlignment="Left"
                                    Style="{StaticResource PrimaryButtonStyle}"
                                    Click="CreateCodeButton_Click" />
                            <TextBlock x:Name="ChildCodeStatusTextBlock"
                                       Text="Create a code before pairing."
                                       Margin="0,16,0,0"
                                       Foreground="{StaticResource MutedTextBrush}" />
                        </StackPanel>
                    </Border>

                    <Border Grid.Column="1"
                            Background="{StaticResource PanelBackgroundBrush}"
                            BorderBrush="{StaticResource BorderBrush}"
                            BorderThickness="1"
                            CornerRadius="8"
                            Padding="24"
                            Margin="12,0,0,0">
                        <StackPanel>
                            <TextBlock Text="Pending Request" FontSize="18" FontWeight="SemiBold" />
                            <Border Background="#F9FAFB"
                                    BorderBrush="{StaticResource BorderBrush}"
                                    BorderThickness="1"
                                    CornerRadius="8"
                                    Padding="14"
                                    Margin="0,18,0,16">
                                <TextBlock Text="No parent request yet."
                                           Foreground="{StaticResource MutedTextBrush}" />
                            </Border>
                            <StackPanel Orientation="Horizontal">
                                <Button Content="Approve"
                                        Width="112"
                                        Style="{StaticResource PrimaryButtonStyle}" />
                                <Button Content="Reject"
                                        Width="112"
                                        Margin="10,0,0,0"
                                        Style="{StaticResource SecondaryButtonStyle}" />
                            </StackPanel>
                        </StackPanel>
                    </Border>
                </Grid>
            </Grid>
        </Grid>
    </Grid>
</Window>
